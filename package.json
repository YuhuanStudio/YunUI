{
  "name": "@yuhuanowo/yunui",
  "version": "0.2.14",
  "description": "A versioned React 19 + Tailwind v4 design system — tokens, primitives, patterns, and AI components, in one package.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "yuhuanowo",
  "packageManager": "pnpm@11.8.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YuhuanStudio/YunUI.git"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "styles",
    "icons",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./patterns": {
      "types": "./dist/patterns.d.ts",
      "import": "./dist/patterns.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    },
    "./css": "./styles/yunui.css",
    "./styles/yunui.css": "./styles/yunui.css"
  },
  "scripts": {
    "build": "node scripts/gen-tokens.mjs && tsup",
    "tokens": "node scripts/gen-tokens.mjs",
    "dev": "node scripts/gen-tokens.mjs && tsup && concurrently -k -n lib,site -c cyan,green \"tsup --watch\" \"pnpm --filter yunui-site dev\"",
    "dev:lib": "tsup --watch",
    "dev:site": "pnpm --filter yunui-site dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist",
    "icons:sync": "node scripts/sync-icons.mjs --apply"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-avatar": "1.1.12",
    "@radix-ui/react-collapsible": "1.1.13",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-popover": "1.1.16",
    "@radix-ui/react-presence": "1.1.6",
    "@radix-ui/react-progress": "1.1.9",
    "@radix-ui/react-radio-group": "^1.4.1",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-slider": "1.4.0",
    "@radix-ui/react-switch": "1.3.0",
    "@radix-ui/react-tabs": "1.1.14",
    "@radix-ui/react-tooltip": "1.2.9",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.40.0",
    "lucide-react": "1.18.0",
    "next-themes": "0.4.6",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@lobehub/icons-static-avatar": "^1.11.0"
  }
}
