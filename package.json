{
  "name": "yunui",
  "version": "0.1.0",
  "description": "YunUI — Yunxin design system extracted into a standalone, versioned UI library (tokens, animations, primitives, patterns).",
  "type": "module",
  "license": "MIT",
  "author": "yuhuanowo",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "styles",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js"
    },
    "./patterns": {
      "types": "./dist/patterns.d.ts",
      "import": "./dist/patterns.js"
    },
    "./ai": {
      "types": "./dist/ai.d.ts",
      "import": "./dist/ai.js"
    },
    "./css": "./styles/yunui.css",
    "./styles/yunui.css": "./styles/yunui.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "tailwindcss": ">=4"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.12",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-presence": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slider": "^1.4.0",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.3.1",
    "tsup": "^8.5.0",
    "typescript": "^6.0.3"
  }
}
